  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="ErrorLogger">
      <DataSourceReference>ErrorLogger</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>1b8d4736-3988-45b8-b18b-cdc0d1b69060</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="dsErrorLog">
      <Query>
        <DataSourceName>ErrorLogger</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@BeginDate">
            <Value>=Parameters!BeginDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT     Title, Timestamp, ProcessID AS UserID, ProcessName, Message
FROM         dbo.[ErrorLog]
WHERE     (Timestamp BETWEEN @BeginDate AND @EndDate) AND Title NOT LIKE '%Trace%'
ORDER BY Timestamp</CommandText>
      </Query>
      <Fields>
        <Field Name="Title">
          <DataField>Title</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Timestamp">
          <DataField>Timestamp</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="UserID">
          <DataField>UserID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ProcessName">
          <DataField>ProcessName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Message">
          <DataField>Message</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="BeginDate">
      <DataType>DateTime</DataType>
      <DefaultValue>
        <Values>
          <Value>=DateAdd(DateInterval.Day, -2, DateTime.Today)</Value>
        </Values>
      </DefaultValue>
      <Prompt>Begin Date</Prompt>
    </ReportParameter>
    <ReportParameter Name="EndDate">
      <DataType>DateTime</DataType>
      <DefaultValue>
        <Values>
          <Value>=DateAdd(DateInterval.Day, 1, DateTime.Today)</Value>
        </Values>
      </DefaultValue>
      <Prompt>End Date</Prompt>
    </ReportParameter>
  </ReportParameters>
  <Language>en-US</Language>
  <ConsumeContainerWhitespace>true</ConsumeContainerWhitespace>
  <rd:ReportUnitType>Inch</rd:ReportUnitType>
  <rd:ReportID>fb38d754-7337-476b-b261-ef8a0b85764b</rd:ReportID>
</Report>